APP_NAME=CCTV People Flow
APP_ENV=development
DEBUG=true
API_HOST=0.0.0.0
API_PORT=8000
DASHBOARD_PORT=5173
# URL ini dipakai browser, sehingga harus dapat dijangkau dari komputer pengguna.
DASHBOARD_API_BASE_URL=http://localhost:8000/api/v1
LOG_LEVEL=INFO
CORS_ALLOWED_ORIGINS=http://localhost:5173
# Default CPU untuk Mac/CPU server. GPU NVIDIA: gunakan index CUDA resmi yang
# cocok dengan driver server, misalnya https://download.pytorch.org/whl/cu124.
TORCH_INDEX_URL=https://download.pytorch.org/whl/cpu

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=cctv
POSTGRES_USER=cctv_user
POSTGRES_PASSWORD=cctv_user
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

STORAGE_PATH=storage
SNAPSHOT_JPEG_QUALITY=95
RTSP_URL=
YOLO_MODEL=yolo11n.pt
CONFIDENCE_THRESHOLD=0.45
YOLO_DEVICE=auto
YOLO_IMAGE_SIZE=640
YOLO_MAX_DETECTIONS=100
YOLO_HALF_PRECISION=true

# ByteTrack
BYTETRACK_FRAME_RATE=10
BYTETRACK_TRACK_HIGH_THRESHOLD=0.5
BYTETRACK_TRACK_LOW_THRESHOLD=0.1
BYTETRACK_NEW_TRACK_THRESHOLD=0.6
BYTETRACK_MATCH_THRESHOLD=0.8
BYTETRACK_TRACK_BUFFER=30
BYTETRACK_HISTORY_SIZE=30
BYTETRACK_DIRECTION_MIN_PIXELS=3.0
BYTETRACK_MAX_INACTIVE_FRAMES=300

# Virtual line crossing
CROSSING_LINE_ID=main-door
CROSSING_LINE_TYPE=horizontal
CROSSING_LINE_POSITION=360
# horizontal: down/up, vertical: right/left. Polygon selalu outside -> inside sebagai ENTER.
CROSSING_ENTER_DIRECTION=down
# Digunakan jika CROSSING_LINE_TYPE=polygon, format: x,y;x,y;x,y
CROSSING_POLYGON_POINTS=
CROSSING_MAX_INACTIVE_FRAMES=300
CROSSING_HYSTERESIS_RATIO=0.01
CROSSING_EVENT_COOLDOWN_FRAMES=3

# Person Re-Identification (OSNet / TorchReID)
REID_MODEL=osnet_x1_0
REID_DEVICE=auto
REID_IMAGE_WIDTH=128
REID_IMAGE_HEIGHT=256
REID_EMBEDDING_DIMENSION=512
REID_SIMILARITY_THRESHOLD=0.78
REID_MATCH_MARGIN=0.05
REID_CANDIDATE_LIMIT=50
REID_MIN_QUALITY_SCORE=0.45
REID_SHARPNESS_REFERENCE=150
REID_EMBEDDING_RETENTION_DAYS=90
REID_MIN_EMBEDDINGS_PER_PERSON=3
REID_MAX_EMBEDDINGS_PER_PERSON=20
REID_RETENTION_INTERVAL_HOURS=24
ENABLE_REID_RETENTION=true

# REST API JWT authentication
JWT_SECRET=replace_with_a_long_random_secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
API_ADMIN_USERNAME=admin
API_ADMIN_PASSWORD=change-this-admin-password
LOGIN_MAX_FAILED_ATTEMPTS=5
LOGIN_LOCK_MINUTES=15

# Sesi masuk tanpa EXIT dari hari sebelumnya ditutup otomatis setelah 00:00.
PRESENCE_TIMEZONE=Asia/Jakarta
PRESENCE_RECONCILE_INTERVAL_SECONDS=30

# Simulator RFID untuk development/testing tanpa reader fisik.
# Jangan aktifkan di production.
ENABLE_RFID_SIMULATOR=false
RFID_SIMULATOR_READER_CODE=SIM-READER-01
RFID_SIMULATOR_READER_NAME=Simulator Pintu Utama
RFID_SIMULATOR_READER_LOCATION=Pintu Utama
RFID_SIMULATOR_EVENT_TTL_SECONDS=30

# Backup observasional harian. Scheduler pada 00:15 membackup tanggal sebelumnya.
ENABLE_BACKUP_SCHEDULER=true
BACKUP_SCHEDULE_TIME=00:15
BACKUP_TIMEZONE=Asia/Jakarta
BACKUP_RETENTION_DAYS=30
BACKUP_INCLUDE_SNAPSHOTS=true
BACKUP_MAX_UPLOAD_MB=2048
BACKUP_MAX_MEMBERS=100000
BACKUP_MAX_EXPANSION_RATIO=100

# Disaster Recovery penuh (dump PostgreSQL + storage, terenkripsi AES-256-GCM).
# Wajib diganti dengan secret acak minimal 16 karakter dan disimpan di secret manager.
ENABLE_DR_SCHEDULER=false
DR_SCHEDULE_TIME=02:00
DR_RETENTION_DAYS=14
DR_ENCRYPTION_PASSPHRASE=replace-with-a-long-random-dr-passphrase
DR_INCLUDE_STORAGE=true
# Mount NAS/offsite ke container lalu isi path ini, contoh /offsite/cctv.
DR_OFFSITE_PATH=
DR_OFFSITE_REQUIRED=false
# Restore normal selalu menuju database isolasi: cctv_restore.
DR_RESTORE_DATABASE_SUFFIX=_restore
DR_ALLOW_IN_PLACE_RESTORE=false
DR_COMMAND_TIMEOUT_SECONDS=3600

# CCTV capture (nilai RTSP dapat diatur per CameraService)
CAMERA_READ_FPS=10
OPENCV_FFMPEG_CAPTURE_OPTIONS=rtsp_transport;tcp|fflags;nobuffer|flags;low_delay|max_delay;0
CAMERA_FRAME_WIDTH=1280
CAMERA_FRAME_HEIGHT=720
CAMERA_RECONNECT_DELAY_SECONDS=3.0
CAMERA_STALE_TIMEOUT_SECONDS=5.0
CAMERA_SYNC_INTERVAL_SECONDS=5.0
DASHBOARD_STREAM_FPS=2.0
DASHBOARD_JPEG_QUALITY=70
CAMERA_HEALTH_UPDATE_SECONDS=30.0
ENABLE_CAMERA_RUNTIME=true
# Pipeline end-to-end tetap memproses kamera walau feed tidak sedang dibuka.
ENABLE_AI_PIPELINE=true
AI_PIPELINE_FPS=5
# CPU/Mac disarankan 1. Naikkan bertahap pada GPU setelah load test.
AI_MAX_CONCURRENT_INFERENCES=1
AI_PERSON_CLASS_ID=0
AI_TRACKING_PERSIST_INTERVAL_SECONDS=1.0
AI_TRACK_INACTIVE_FRAMES=60
AI_EVENT_RETRY_QUEUE_SIZE=1000
REID_MIN_CROP_WIDTH=32
REID_MIN_CROP_HEIGHT=64
# 0 mempertahankan default library. Atur saat banyak kamera berbagi CPU.
TORCH_NUM_THREADS=0
OPENCV_NUM_THREADS=0
